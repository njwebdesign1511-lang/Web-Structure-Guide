{
  "buildCommand": "pnpm --filter @workspace/api-spec run codegen && pnpm --filter @workspace/albert-auto-detailing run build && node api/build.mjs",
  "outputDirectory": "artifacts/albert-auto-detailing/dist/public",
  "installCommand": "corepack enable && pnpm install --no-frozen-lockfile",
  "functions": {
    "api/index.ts": {
      "memory": 1024,
      "maxDuration": 30,
      "includeFiles": "api/dist/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" }
  ]
}
