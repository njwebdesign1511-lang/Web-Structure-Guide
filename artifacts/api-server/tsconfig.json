{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "incremental": true,
    "tsBuildInfoFile": ".tsbuildinfo",
    "outDir": "dist",
    "rootDir": "src",
    "types": ["node"],
    "moduleResolution": "bundler",
    "module": "ESNext",
    "noImplicitAny": false,
    "skipLibCheck": true,
    "allowImportingTsExtensions": false
  },
  "include": ["src"]
}
